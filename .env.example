# ================================================================
# SSDLC + SBOM Pipeline — Environment Variables
# ================================================================
# Copy this file to .env and edit values.
# Usage: cp .env.example .env
# ================================================================

# ===== OWASP Dependency-Track (required for all scanners) =====
DTRACK_URL=http://dtrack-apiserver:8080
DTRACK_API_KEY=your-api-key-here

# ===== Grype Threshold =====
# Severity level to monitor: negligible | low | medium | high | critical
GRYPE_SEVERITY=critical
# Action when threshold hit: info | warning | block
GRYPE_MODE=block

# ===== Git Scanner — Option A: repos file (recommended for multi-repo) =====
GIT_REPOS_FILE=/repos-config/repos.txt
GIT_REPOS_FILE_HOST=./SyftGrypeScan/repos.example.txt

# ===== Git Scanner — Option B: env var list =====
# GIT_REPOS=https://github.com/org/repo1.git,https://github.com/org/repo2.git

# ===== Git Scanner — Option C: single repo (backward compatible) =====
# GIT_REPO_URL=https://github.com/your-org/your-repo.git
# GIT_BRANCH=main

# ===== Local Scanner =====
LOCAL_SCAN_PATH=.
# DTRACK_PROJECT_NAME=my-project
# DTRACK_PROJECT_VERSION=1.0.0

# ===== JavaScript/NPM Cataloger Options =====
# By default, Syft excludes devDependencies from package-lock.json scans.
# Set this to true if you want to scan and include devDependencies.
# SYFT_JAVASCRIPT_INCLUDE_DEV_DEPENDENCIES=true
